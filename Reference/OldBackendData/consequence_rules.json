{
  "consequence_rules": [
    {
      "rule_id": "merchant_killed_price_rise",
      "trigger_type": "npc_killed",
      "conditions": {
        "npc_role": "merchant"
      },
      "effects": [
        {
          "type": "update_location_price",
          "target": "current",
          "params": {
            "delta_pct": 30
          },
          "description": "Merchant killed - local prices rise 30%"
        }
      ],
      "delay_hours": 0,
      "probability": 1.0,
      "description": "Killing a merchant raises local prices"
    },
    {
      "rule_id": "merchant_killed_reputation",
      "trigger_type": "npc_killed",
      "conditions": {
        "npc_role": "merchant"
      },
      "effects": [
        {
          "type": "update_faction_rep",
          "target": "merchants_guild",
          "params": {
            "delta": -20
          },
          "description": "Merchants guild reputation -20"
        }
      ],
      "delay_hours": 0,
      "probability": 1.0
    },
    {
      "rule_id": "witnessed_kill_guards_alert",
      "trigger_type": "npc_killed",
      "conditions": {
