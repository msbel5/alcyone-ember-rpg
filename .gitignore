# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# IDE/generated project files
.vs/
.idea/
.vscode/
*.csproj
*.sln
*.slnx
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Prototype art — 1.5GB of generated/third-party imagery from the
# ember-rpg scaffold. Kept on disk but out of git until real Ember
# art lands. Re-include selectively.
Assets/Art/Prototype/
Assets/Art/Prototype.meta

# References (locally cloned/extracted, NOT pushed - too big)
references/
# Repo-local validation evidence/generated harness artifacts
validation-output/
!tools/validation/fallback/*.csproj

# Local scratch / draft / review artefacts (transient working dir)
.tmp/


# Build artifacts (gitignored — produced via Ember/Build menu)
Builds/

# Unity AI Toolkit cache (per-machine)
Assets/AI Toolkit/Temp/
Assets/AI Toolkit/Temp.meta

# SDXL Turbo external-data shards exceed GitHub LFS' 2GB per-object limit.
# Keep them local or download them during model bootstrap; do not publish them.
Assets/StreamingAssets/Models/sdxl-turbo/unet/model.onnx.data
Assets/StreamingAssets/Models/sdxl-turbo/text_encoder_2/model.onnx.data
# HYG-03: the .onnx.data payloads are ignored above, so their Unity .meta must be too
# (otherwise a clean clone gets a tracked .meta with no asset = dangling import).
Assets/StreamingAssets/Models/sdxl-turbo/*/model.onnx.data.meta

# Unity Performance Testing auto-generated run info (rewritten on every test run
# with whichever packages happen to be installed locally — including dev-only
# `com.unity.ai.assistant`. Keep it out of git so CI/Mami machines don't diff.)
Assets/Resources/PerformanceTestRunInfo.json
Assets/Resources/PerformanceTestRunInfo.json.meta

# Codex audit Batch 4: Unity Editor sometimes inlines per-machine package
# sources (Unity AI Assistant, Inference, etc.) under Packages/. Track only
# the manifest + lock; never commit the embedded package source trees.
Packages/*/
!Packages/manifest.json
!Packages/packages-lock.json

# (EMB-026) The com.unity.ai.assistant embedded package was removed; its re-include
# exception is gone. Packages/*/ keeps any locally-inlined package source out of git.

# Unity convention: any folder suffixed with ~ is ignored by Unity (docs, build
# artifacts, third-party binaries). Skip them in the embedded ai.assistant too —
# RelayApp~ alone contains a 114 MB relay_win.exe that exceeds GitHub's hard
# 100 MB file size limit, and the chat UI degrades to its built-in fallback
# without those binaries.
Packages/com.unity.ai.assistant/*~/
Packages/com.unity.ai.assistant/*~

# CI / validation artifacts produced by Reports/* runs — keep PRD reports + screenshots, drop logs / xml / temp builds
Reports/*.log
Reports/*.xml
Reports/test-results-*.xml
Reports/test-results-*.log
Reports/unity_compile*.log
Reports/validation-fallback*.log
Reports/build-windows64*.log
Reports/build-*.log
Reports/*.tmp
# Proof-run screenshots are REPRODUCIBLE artifacts (the build regenerates them via
# --ember-lookaround/looptest/shipcheck); the durable record is the roadmap KANIT text +
# Player.log lines. ~430MB of iteration PNGs do not belong in history.
Reports/proof-*/
Reports/proofs/
Reports/shipcheck-*/

# cuDNN 9 redistributable DLLs are huge (~830MB). Devs install locally
# from https://developer.nvidia.com/cudnn-9-archive and copy into
# Assets/Plugins/x86_64/cuda/. The forge picks them up at runtime.
Assets/Plugins/x86_64/cuda/cudnn*.dll
# HYG-02: the cuDNN DLLs are ignored above; ignore their Unity .meta too so a stray
# `git add -A` can't commit orphan metas whose DLL is absent on a clean clone.
Assets/Plugins/x86_64/cuda/cudnn*.dll.meta

# EMB-052 — secrets must never be committed. Keys/endpoints are read from
# environment variables only (e.g. EMBER_LOCAL_LLM_ENDPOINT, the cloud LLM
# ApiKey passed via CloudLlmConfig). Ignore any local secret/key material:
.env
.env.*
*.env
secrets.json
**/secrets.json
*.key
*.pem
*.pfx
*.p12
**/appsettings.*.local.json

# EMB-021 — generated-asset policy: runtime image generation is a per-playthrough
# cache on the player's machine, not tracked source. Only seed manifests / curated
# authored art are tracked. Regenerated outputs are ignored:
# Ignore only the root-level scratch export folder. Do not hide
# Assets/Resources/GeneratedAssets, which is the runtime Resources database.
/GeneratedAssets/
# keep the Core/ folder + its .meta tracked (stable runtime-output location);
# ignore only the regenerated image/json outputs so they never get staged:
Assets/Generated/Core/*.png
Assets/Generated/Core/*.png.meta
Assets/Generated/Core/*.json
Assets/Generated/Core/*.jpg
Assets/Generated/Core/*.jpg.meta
Assets/Generated/Core/*.promptmeta
Assets/Generated/Core/*.promptmeta.meta
Assets/Generated/_backup_*/
Assets/Generated/_backup_*.meta

# Local matte/segmentation models are downloaded on demand and must not be
# committed. Keep the source path configurable; keep binaries out of Git.
Assets/StreamingAssets/Models/matte/
Assets/StreamingAssets/Models/matte.meta

# Codex sandbox validation redirects
.validation-appdata/
.validation-dotnet-home/
Assets/StreamingAssets/Models/tts/
Assets/StreamingAssets/Models/tts.meta
