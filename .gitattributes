# Git LFS — large binary assets imported from the prototype art library
Assets/Art/**/*.png filter=lfs diff=lfs merge=lfs -text
Assets/Art/**/*.jpg filter=lfs diff=lfs merge=lfs -text
Assets/Art/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
Assets/Art/**/*.webp filter=lfs diff=lfs merge=lfs -text
Assets/Art/**/*.tga filter=lfs diff=lfs merge=lfs -text
Assets/Art/**/*.psd filter=lfs diff=lfs merge=lfs -text
Assets/Art/**/*.fbx filter=lfs diff=lfs merge=lfs -text
Assets/Art/**/*.wav filter=lfs diff=lfs merge=lfs -text
Assets/Art/**/*.ogg filter=lfs diff=lfs merge=lfs -text
Assets/Art/**/*.mp3 filter=lfs diff=lfs merge=lfs -text
# AI model files + native DLLs (pure C# ONNX/LLamaSharp backend)
*.gguf filter=lfs diff=lfs merge=lfs -text
*.onnx filter=lfs diff=lfs merge=lfs -text
Assets/Plugins/x86_64/*.dll filter=lfs diff=lfs merge=lfs -text
Assets/Plugins/x86_64/cuda/*.dll filter=lfs diff=lfs merge=lfs -text
Assets/Plugins/x86_64/*.so filter=lfs diff=lfs merge=lfs -text
Assets/Plugins/x86_64/*.dylib filter=lfs diff=lfs merge=lfs -text
# Line endings
*.cs text eol=lf
*.shader text eol=lf
*.meta text eol=lf
*.unity text eol=lf
*.asset text eol=lf
*.prefab text eol=lf
*.mat text eol=lf
*.asmdef text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sln text eol=crlf
*.csproj text eol=crlf
*.onnx.data filter=lfs diff=lfs merge=lfs -text
*.pb filter=lfs diff=lfs merge=lfs -text

# Embedded Unity AI Assistant package binaries (see .gitignore for context).
Packages/com.unity.ai.assistant/**/*.dll filter=lfs diff=lfs merge=lfs -text
Packages/com.unity.ai.assistant/**/*.so filter=lfs diff=lfs merge=lfs -text
Packages/com.unity.ai.assistant/**/*.dylib filter=lfs diff=lfs merge=lfs -text
Packages/com.unity.ai.assistant/**/*.pdb filter=lfs diff=lfs merge=lfs -text
Packages/com.unity.ai.assistant/**/*.bytes filter=lfs diff=lfs merge=lfs -text
Packages/com.unity.ai.assistant/**/*.onnx filter=lfs diff=lfs merge=lfs -text
