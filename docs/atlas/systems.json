[
 {
  "file": "docs/atlas/systems/01-time-cadence.md",
  "name": "time-cadence",
  "oneLiner": "Deterministic integer clock (1 tick = 1 game minute) driving three cadence bands (PerTick/Hourly/Daily) via boundary-stamped per-tick replay; chunked and tick-by-tick advancement produce byte-identical history.",
  "writes": [
   "World.Time"
  ],
  "reads": [
   "World.Actors (null-gate for Hourly band)",
   "World.Events (null-gate for Hourly/Daily bands)",
   "EmberRuntimeOptionsProvider.Current.Tick (MinutesPerTick, TicksPerHour, TicksPerDay)"
  ],
  "events": [
   "DayAdvanced (dead at runtime - only the test-called 4-arg Advance overload emits it)",
   "SeasonChanged (dead at runtime - same overload)",
   "TickPerf (EmberLog warn tag, slow ticks >12ms)"
  ],
  "tags": [
   "determinism",
   "cadence",
   "reform-2",
   "field-ownership",
   "catch-up",
   "replay",
   "boundary-stamp",
   "error-family-c"
  ]
